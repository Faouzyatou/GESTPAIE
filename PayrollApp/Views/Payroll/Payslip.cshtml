@model PayrollApp.Services.Payslip

@{
    ViewData["Title"] = "Payslip";
}

<h1>Payslip</h1>

<div>
    <h4>Payslip</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Employee ID
        </dt>
        <dd class="col-sm-10">
            @Model.EmployeeId
        </dd>
        <dt class="col-sm-2">
            Date
        </dt>
        <dd class="col-sm-10">
            @Model.Date.ToShortDateString()
        </dd>
        <dt class="col-sm-2">
            Gross Salary
        </dt>
        <dd class="col-sm-10">
            @Model.GrossSalary.ToString("C")
        </dd>
        <dt class="col-sm-2">
            Net Salary
        </dt>
        <dd class="col-sm-10">
            @Model.NetSalary.ToString("C")
        </dd>
    </dl>
</div>

<table class="table">
    <thead>
        <tr>
            <th>Code</th>
            <th>Label</th>
            <th>Amount</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.PayslipItems)
        {
            <tr>
                <td>@item.Code</td>
                <td>@item.Label</td>
                <td>@item.Amount.ToString("C")</td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="ExportToCsv" asp-route-employeeId="@Model.EmployeeId" asp-route-date="@Model.Date.ToString("yyyy-MM-dd")" class="btn btn-primary">Export to CSV</a>
